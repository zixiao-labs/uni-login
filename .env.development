# GitHub OAuth application client id (public). Server holds the secret.
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:5173/oauth/callback
VITE_GITHUB_CLIENT_ID=

# Where to redirect after successful login. In dev the main console runs on :5174.
VITE_MAIN_CONSOLE_URL=http://localhost:5174/

# Backend API base URL (yuxu-server). Leave empty in prod for same-origin.
VITE_API_BASE_URL=http://localhost:8080
