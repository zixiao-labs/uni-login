# GitHub OAuth application client id (public). Server holds the secret.
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:5173/oauth/callback
VITE_GITHUB_CLIENT_ID=

# Where to redirect after a plain sign-in (not an OAuth authorize flow).
# In dev the main yuxu console runs on :5174.
VITE_MAIN_CONSOLE_URL=http://localhost:5174/

# Backend API base URL for Zixiao Labs Cloud Account's own backend.
# Leave empty in prod for same-origin. The dev value targets the
# companion Rust service under ./server (default port 5180).
VITE_API_BASE_URL=http://localhost:5180
