# Copy to .env and adjust. Loaded automatically by the server via dotenvy.

# --- Server bind address ---
ZXCLOUD_BIND=0.0.0.0:5180

# --- Database ---
DATABASE_URL=sqlite://zxcloud.db?mode=rwc

# --- JWT ---
# REQUIRED. >=32 bytes. Used to sign both session JWTs (issued to SPA clients
# after a password login) and OAuth access tokens (issued to relying parties
# after a successful token exchange). Generate with:
#   openssl rand -base64 48
ZXCLOUD_JWT_SECRET=replace-me-with-a-32-plus-byte-random-secret-value

# Session JWT lifetime (seconds). Defaults to 86400 (24h).
ZXCLOUD_SESSION_TTL_SECS=86400

# OAuth access-token lifetime (seconds). Defaults to 3600 (1h).
ZXCLOUD_ACCESS_TOKEN_TTL_SECS=3600

# Authorization-code lifetime (seconds). Defaults to 120 (2 min).
# Codes are single-use; this is the max window between authorize and token.
ZXCLOUD_CODE_TTL_SECS=120

# --- Registered OAuth clients ---
# Single-client registry for now. `ZXCLOUD_CLIENTS` is a semicolon-separated
# list of `client_id,client_secret,redirect_uri_prefix` triples. The
# redirect_uri sent by the client must START WITH the configured prefix.
# Example (yuxu-server dev + prod):
#   ZXCLOUD_CLIENTS=yuxu-dev,super-secret,http://localhost:8080/;yuxu-prod,another-secret,https://yuxu.example.com/
ZXCLOUD_CLIENTS=

# --- CORS ---
# Comma-separated list. Empty disables CORS (same-origin only).
# ZXCLOUD_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Logging ---
# RUST_LOG=zxcloud_account_server=debug,tower_http=info
